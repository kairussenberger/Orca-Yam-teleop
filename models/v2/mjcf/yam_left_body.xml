<?xml version='1.0' encoding='utf-8'?>
<!-- I2RT YAM arm (LEFT), 5-DoF, compiled from left_yam_arm_description.
     Body tree only; mesh assets + actuators live in yam_left.mjcf, which the
     scene includes alongside this file. Frames/inertials come straight from the
     URDF (meshes authored in the base frame, hence the large per-geom offsets).

     gravcomp="1" makes each link weightless so the light position servos in
     yam_left.mjcf hold the home pose without sag or oscillation; the arm is a
     static mount in phase 1 (hands-only teleop). Geoms are visual-only
     (contype/conaffinity 0) so the arm never fights the hand in contact. -->
<!-- The "yam_arm" default class (joint damping/armature + visual geom style) is
     defined once in the scene file, so both arms can share it without a
     duplicate-class clash. -->
<mujoco model="yam_left_body">
  <body name="left_arm_base_link" childclass="yam_arm" gravcomp="1">
    <inertial pos="0.0196489 -0.0604437 -0.0167441" quat="0.499974 0.500809 -0.499362 0.499853" mass="2.64335" diaginertia="0.005192 0.004555 0.002293"/>
    <geom mesh="left_arm_base_link"/>
    <body name="left_arm_link1" pos="0.066479 -0.060421 -0.016708" gravcomp="1">
      <inertial pos="0.0237207 0.00743786 0.0026178" quat="0.471673 0.0280323 0.0461507 0.880119" mass="0.489443" diaginertia="0.000653092 0.000515257 0.000227651"/>
      <joint name="left_arm_j1" axis="1 0 0" range="0 6.283185"/>
      <geom mesh="left_arm_link1" pos="-0.066479 0.060421 0.016708"/>
      <body name="left_arm_link2" pos="0.0455 0.02 -0.0306" gravcomp="1">
        <inertial pos="0.000134809 0.126958 0.0321243" quat="0.707029 0.707185 -9.7142e-06 -9.71634e-06" mass="7.71623" diaginertia="0.076986 0.076618 0.004203"/>
        <joint name="left_arm_j2" axis="0 0 1" range="-2.879793 0.436332"/>
        <geom mesh="left_arm_link2" pos="-0.111979 0.040421 0.047308"/>
        <body name="left_arm_link3" pos="1e-06 0.2596 0.06575" gravcomp="1">
          <inertial pos="0.0556114 0.135063 -0.0357995" quat="0.704454 0.697187 -0.12128 0.0544698" mass="6.44799" diaginertia="0.0501753 0.050026 0.0057497"/>
          <joint name="left_arm_j3" axis="0 0 1" range="-1.396263 2.443461"/>
          <geom mesh="left_arm_link3" pos="-0.11198 -0.219179 -0.018442"/>
          <body name="left_arm_link4" pos="0.06 0.241549 -0.00205" gravcomp="1">
            <inertial pos="0.0543495 0.0570603 -0.0330658" quat="0.253742 0.371718 0.626251 0.636593" mass="1.81627" diaginertia="0.00318152 0.0030776 0.00114988"/>
            <joint name="left_arm_j4" axis="0 0 1" range="-1.570796 1.570796"/>
            <geom mesh="left_arm_link4" pos="-0.17198 -0.460728 -0.016392"/>
            <body name="left_arm_link5" pos="0.0403 0.070162 -0.0339" gravcomp="1">
              <inertial pos="-0.037954 0.0123024 1.93088e-06" quat="0.404826 0.579755 -0.404826 0.579755" mass="1.3789" diaginertia="0.000865 0.000778447 0.000614553"/>
              <joint name="left_arm_j5" axis="-1 0 0" range="-1.570796 1.570796"/>
              <geom mesh="left_arm_link5" pos="-0.21228 -0.53089 0.017508"/>

              <!-- ===== flange (link5) -> ORCA hand base transform =====
                   pos sets the CONTACT: tower square back-face center aligned onto
                   link5's circular flange center (0.00mm gap), faces flush. From CAD
                   (`full base + hand attached.stl`): link5 circle ctr (-40.5,49.8,0)mm
                   in link5 frame, tower square ctr (-9.9,-58,0)mm in tower frame ->
                   pos = circle - Ry(pi)*square. euler "0 pi 0" = 180deg roll about
                   the finger axis -> palm-DOWN, thumb-INWARD at -X home (right arm
                   uses euler 0 to match). -->
              <!-- Wrist-roll joint (the joint cut from the supplied URDF): the
                   hand spins on link5's circular flange instead of being welded.
                   axis (0 1 0) = the flange normal in the link5 frame (mesh-
                   measured: +Y), which euler "0 pi 0" leaves as +Y in this body
                   frame too. pos = flange/circle center expressed in this rotated
                   frame = the tower square center, so the hand rotates TRUE on the
                   flange (not orbiting an offset axis). j6=0 is the welded
                   reference, preserving the verified flush 0.00mm contact. Range
                   is a PLACEHOLDER (+/-180deg) -> refine to the real YAM wrist
                   limit; harmless in phase 1 since j6 holds home (0). -->
              <body name="left_hand_mount" pos="-0.0504 0.1078 0" euler="0 3.14159 0">
                <joint name="left_arm_j6" axis="0 1 0" pos="-0.0099 -0.058 0" range="-3.14159 3.14159"/>
                <include file="orcahand_left_body.xml"/>
              </body>
            </body>
          </body>
        </body>
      </body>
    </body>
  </body>
</mujoco>
