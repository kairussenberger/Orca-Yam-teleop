<?xml version="1.0" ?>
<!-- Bimanual YAM arms, each carrying an ORCA hand on its flange.

     Composition mirrors scene_combined.xml: shared scene/options, the two hand
     asset+actuator mjcfs, plus the two arm asset+actuator mjcfs. Each arm body
     (yam_*_body.xml) nests its ORCA hand body at the flange, so one model holds
     2 arms (5 joints each) + 2 hands (17 actuators each).

     PHASE 1 = hands-only teleop: the 34 hand actuators are driven from the
     webcam; the 10 arm actuators just hold a home pose (default ctrl 0).

     PLACEHOLDERS waiting on real measurements:
       * arm base pose per side (below)            -> user item #3
       * flange -> hand transform (in yam_*_body)  -> user item #2
     Tweak only those; everything else is derived from the URDF. -->
<mujoco model="bimanual YAM + ORCA hands">

  <include file="../../models/v2/assets/options.xml"/>
  <include file="../../models/v2/assets/scene.xml"/>

  <include file="../../models/v2/mjcf/orcahand_left.mjcf"/>
  <include file="../../models/v2/mjcf/orcahand_right.mjcf"/>
  <include file="../../models/v2/mjcf/yam_left.mjcf"/>
  <include file="../../models/v2/mjcf/yam_right.mjcf"/>

  <!-- Real stand: "Assembly Frame 60x60 for Agilex Robotics Ranger". One STL,
       213k tris > MuJoCo's 200k limit, so it is split into two visual sub-meshes
       (full fidelity, no decimation). mm -> m via scale. -->
  <asset>
    <mesh name="stand_part0" file="../../models/v2/assets/stand/frame_part0.stl" scale="0.001 0.001 0.001"/>
    <mesh name="stand_part1" file="../../models/v2/assets/stand/frame_part1.stl" scale="0.001 0.001 0.001"/>
  </asset>

  <!-- Shared arm-link style; defined once here so both arm body files can use
       childclass="yam_arm" without each redefining (and clashing on) it. -->
  <default>
    <default class="yam_arm">
      <joint damping="2.0" armature="0.1"/>
      <geom type="mesh" contype="0" conaffinity="0" group="2" rgba="0.75 0.75 0.78 1"/>
    </default>
  </default>

  <statistic extent="1.3" center="0 0 0.6"/>

  <worldbody>
    <!-- Stand mesh, lifted so its feet (min z = -0.2475 m) sit on the floor.
         Visual-only. Its two side bosses are the arm mounts (measured from the
         mesh): left face (-0.040,-0.048,0.365) m, right face (0.030,-0.048,0.365),
         both shifted by the same +0.2475 z lift below. -->
    <body name="stand" pos="0 0 0.2475">
      <geom type="mesh" mesh="stand_part0" contype="0" conaffinity="0" rgba="0.62 0.64 0.68 1"/>
      <geom type="mesh" mesh="stand_part1" contype="0" conaffinity="0" rgba="0.62 0.64 0.68 1"/>
    </body>

    <!-- Both arm base poses RECOVERED by ICP-registering the canonical YAM
         base_link mesh onto the user's CAD export `assembly example both arms.stl`
         (RMS 1.6 / 1.3 mm -> both mounts are this same YAM, hence yam_right_body
         is now real left-geometry, not an x-mirror). Each arm bolts to a vertical
         plate on a Y-face of the upper structure, same height (world z ~0.69).
         LEFT base on the -Y face (joint-1 axis -> world -Y); RIGHT base on the +Y
         face (joint-1 axis -> world +Y) = the left pose rotated 180deg about Z.
         At q=0 each arm points world +Z (up); the per-side home pose in
         sim_yam_bimanual.py (j1 = +/-90 deg) swings them to face FORWARD (world
         -X) instead of reaching apart along +/-Y. quat is (w x y z). -->
    <body name="left_arm_base" pos="-0.0248 -0.1700 0.6908" quat="0.49791 0.50194 -0.50011 -0.50004">
      <include file="../../models/v2/mjcf/yam_left_body.xml"/>
    </body>
    <body name="right_arm_base" pos="0.0101 0.0801 0.6875" quat="0.49989 0.49988 0.50055 0.49968">
      <include file="../../models/v2/mjcf/yam_right_body.xml"/>
    </body>
  </worldbody>

</mujoco>
