<?xml version="1.0" ?>
<!-- Bimanual YAM arms, each carrying an ORCA hand on its flange.

     Composition mirrors scene_combined.xml: shared scene/options, the two hand
     asset+actuator mjcfs, plus the two arm asset+actuator mjcfs. Each arm body
     (yam_*_body.xml) nests its ORCA hand body at the flange via a wrist-roll
     joint, so one model holds 2 arms (6 joints each: 5 URDF + the wrist-roll j6
     at the flange) + 2 hands (17 actuators each).

     PHASE 1 = hands-only teleop: the 34 hand actuators are driven from the
     webcam; the 12 arm actuators just hold a home pose (default ctrl 0).

     PLACEHOLDERS waiting on real measurements:
       * arm base pose per side (below)            -> user item #3
       * flange -> hand transform (in yam_*_body)  -> user item #2
     Tweak only those; everything else is derived from the URDF. -->
<mujoco model="bimanual YAM + ORCA hands">

  <include file="../../models/v2/assets/options.xml"/>
  <include file="../../models/v2/assets/scene.xml"/>

  <include file="../../models/v2/mjcf/orcahand_left.mjcf"/>
  <include file="../../models/v2/mjcf/orcahand_right.mjcf"/>
  <include file="../../models/v2/mjcf/yam_left.mjcf"/>
  <include file="../../models/v2/mjcf/yam_right.mjcf"/>

  <!-- Real stand: the ELONGATED "Assembly Frame 60x60 for Agilex Robotics Ranger"
       (same 270x400 mm footprint as before, but 1230 mm tall = +500 mm vs the old
       730 mm version, so the arms ride high enough that the hands clear the floor).
       One STL, 1.05M tris >> MuJoCo's 200k/mesh limit, so it is split into six
       visual sub-meshes (full fidelity, no decimation). mm -> m via scale. -->
  <asset>
    <mesh name="stand_part0" file="../../models/v2/assets/stand/frame_part0.stl" scale="0.001 0.001 0.001"/>
    <mesh name="stand_part1" file="../../models/v2/assets/stand/frame_part1.stl" scale="0.001 0.001 0.001"/>
    <mesh name="stand_part2" file="../../models/v2/assets/stand/frame_part2.stl" scale="0.001 0.001 0.001"/>
    <mesh name="stand_part3" file="../../models/v2/assets/stand/frame_part3.stl" scale="0.001 0.001 0.001"/>
    <mesh name="stand_part4" file="../../models/v2/assets/stand/frame_part4.stl" scale="0.001 0.001 0.001"/>
    <mesh name="stand_part5" file="../../models/v2/assets/stand/frame_part5.stl" scale="0.001 0.001 0.001"/>
  </asset>

  <!-- Shared arm-link style; defined once here so both arm body files can use
       childclass="yam_arm" without each redefining (and clashing on) it. -->
  <default>
    <default class="yam_arm">
      <joint damping="2.0" armature="0.1"/>
      <geom type="mesh" contype="0" conaffinity="0" group="2" rgba="0.75 0.75 0.78 1"/>
    </default>
  </default>

  <statistic extent="1.6" center="0 0 0.8"/>

  <worldbody>
    <!-- Stand mesh, lifted so its feet (mesh min z = -0.2139 m) sit on the floor.
         Visual-only. The small XY offset (+0.0017, -0.0210) re-aligns the new
         export's mount faces onto exactly where the old frame's were, so the arm
         bases (below) still bolt to the same spot on the frame - only now 0.5 m
         higher, because the elongated frame is 0.5 m taller. -->
    <body name="stand" pos="0.0017 -0.0210 0.2139">
      <geom type="mesh" mesh="stand_part0" contype="0" conaffinity="0" rgba="0.62 0.64 0.68 1"/>
      <geom type="mesh" mesh="stand_part1" contype="0" conaffinity="0" rgba="0.62 0.64 0.68 1"/>
      <geom type="mesh" mesh="stand_part2" contype="0" conaffinity="0" rgba="0.62 0.64 0.68 1"/>
      <geom type="mesh" mesh="stand_part3" contype="0" conaffinity="0" rgba="0.62 0.64 0.68 1"/>
      <geom type="mesh" mesh="stand_part4" contype="0" conaffinity="0" rgba="0.62 0.64 0.68 1"/>
      <geom type="mesh" mesh="stand_part5" contype="0" conaffinity="0" rgba="0.62 0.64 0.68 1"/>
    </body>

    <!-- Both arm base poses RECOVERED by ICP-registering the canonical YAM
         base_link mesh onto the user's CAD export `assembly example both arms.stl`
         (RMS 1.6 / 1.3 mm -> both mounts are this same YAM, hence yam_right_body
         is now real left-geometry, not an x-mirror). Each arm bolts to a vertical
         plate on a Y-face of the upper structure, same height. Both z values were
         raised +0.5 m (0.69 -> 1.19) to track the elongated frame's mount, which
         is 0.5 m higher; XY/quat are unchanged from the registration.
         LEFT base on the -Y face (joint-1 axis -> world -Y); RIGHT base on the +Y
         face (joint-1 axis -> world +Y) = the left pose rotated 180deg about Z.
         At q=0 each arm points world +Z (up); the per-side home pose in
         sim_yam_bimanual.py (j1 = +/-90 deg) swings them to face FORWARD (world
         -X) instead of reaching apart along +/-Y. quat is (w x y z). -->
    <body name="left_arm_base" pos="-0.0248 -0.1700 1.1908" quat="0.49791 0.50194 -0.50011 -0.50004">
      <include file="../../models/v2/mjcf/yam_left_body.xml"/>
    </body>
    <body name="right_arm_base" pos="0.0101 0.0801 1.1875" quat="0.49989 0.49988 0.50055 0.49968">
      <include file="../../models/v2/mjcf/yam_right_body.xml"/>
    </body>
  </worldbody>

</mujoco>
